opt_out_usage

default_platform(:ios)

platform :ios do
  desc "Upload screenshots and metadata to App Store Connect (fastlane 2.234+)"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    version = ENV["ASC_APP_VERSION"]
    UI.user_error!("Set ASC_APP_VERSION (run: eval \"$(python3 scripts/asc-ensure-draft-version.py | grep '^export ')\")") unless version && !version.empty?

    skip_shots = ENV.fetch("SKIP_SCREENSHOTS", "false") == "true"

    deliver(
      api_key: api_key,
      app_version: version,
      skip_app_version_update: true,
      force: true,
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
      version_check_wait_retry_limit: 7,
      skip_binary_upload: true,
      skip_screenshots: skip_shots,
      overwrite_screenshots: !skip_shots,
      submit_for_review: false,
      automatic_release: false,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Upload metadata (incl. name/subtitle appInfo) and submit for review with auto-release"
  lane :submit_release do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    version = ENV["ASC_APP_VERSION"]
    UI.user_error!("Set ASC_APP_VERSION") unless version && !version.empty?

    deliver(
      api_key: api_key,
      app_version: version,
      skip_app_version_update: false,
      force: true,
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
      version_check_wait_retry_limit: 7,
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      run_precheck_before_submit: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Build and upload to TestFlight"
  lane :deploy_testflight do
    api_key = app_store_connect_api_key(
      key_id: "9T82M4AZQ2",
      issuer_id: "331fd693-6cf0-4ea7-9a9f-ee03b01b3f6d",
      key_filepath: "/Users/jackwallner/.appstoreconnect/AuthKey_9T82M4AZQ2.p8"
    )

    build_app(
      scheme: "HeadacheLogger",
      project: "HeadacheLogger.xcodeproj",
      export_method: "app-store",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
